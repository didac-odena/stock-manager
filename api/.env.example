# Copy this file to .env and fill in the values.
# Do NOT commit the real .env (api/.gitignore already excludes it).

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/stock-manager-dev
TOKEN_SECRET=replace-with-a-long-random-string

# Optional (defaults in code)
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Required for image uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
