    {
      "name": "Day 11 - Auth + Services (/api)",
      "description": "Run with backend running on port 3000. Postman cookie jar keeps the auth cookie.",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiBaseUrl}}/api/health",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          }
        },
        {
          "name": "GET /api/categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiBaseUrl}}/api/categories",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            }
          }
        },
        {
          "name": "POST /api/login (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{apiBaseUrl}}/api/login",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          }
        },
        {
          "name": "GET /api/me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiBaseUrl}}/api/me",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "me"
              ]
            }
          }
        },
        {
          "name": "GET /api/products (save productId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body && Array.isArray(body.data) && body.data.length > 0 && body.data[0]._id) {",
                  "  pm.collectionVariables.set(\"productId\", body.data[0]._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiBaseUrl}}/api/products",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          }
        },
        {
          "name": "GET /api/products/:id/reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiBaseUrl}}/api/products/{{productId}}/reviews",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}",
                "reviews"
              ]
            }
          }
        },
        {
          "name": "POST /api/products/:id/reviews",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{reviewEmail}}\",\n  \"rating\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{apiBaseUrl}}/api/products/{{productId}}/reviews",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}",
                "reviews"
              ]
            }
          }
        },
        {
          "name": "POST /api/logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{apiBaseUrl}}/api/logout",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "logout"
              ]
            }
          }
        },
        {
          "name": "GET /api/me (expect 401 after logout)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiBaseUrl}}/api/me",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "api",
                "me"
              ]
            }
          }
        }
      ]
