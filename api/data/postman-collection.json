        {
          "name": "POST Create Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) {",
                  "    pm.collectionVariables.set('invitationToken', json.token);",
                  "  }",
                  "}"
                ]
              }
            }
