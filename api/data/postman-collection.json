        {
          "name": "POST Create Product With Images",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const productId = json.id || json._id || '';",
                  "  const barcode = json.barcode || '';",
                  "  if (productId) pm.collectionVariables.set('productId', productId);",
                  "  if (barcode) pm.collectionVariables.set('productBarcode', barcode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "T-Shirt With Photo",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Created from Postman using multipart form-data",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "29.99",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "10",
                  "type": "text"
                },
                {
                  "key": "categories",
                  "value": "Ropa",
                  "type": "text"
                },
                {
                  "key": "barcode",
                  "value": "{{productBarcode}}",
                  "type": "text"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Attach your image in the `images` field. In Postman Body > form-data, the `images` row must be type File."
          },
          "response": []
        },
