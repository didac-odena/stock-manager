    {
      "name": "2) Products - Protected CRUD",
      "item": [
        {
          "name": "Create Product (With Barcode)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const productId = json.id || json._id || '';",
                  "  const barcode = json.barcode || '';",
                  "  if (productId) pm.collectionVariables.set('createdProductId', productId);",
                  "  if (barcode) pm.collectionVariables.set('createdProductBarcode', barcode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Zapatillas Pro\",\n  \"description\": \"Modelo de test para dia 7\",\n  \"price\": 89.99,\n  \"stock\": 15,\n  \"categories\": [\"Deportes\", \"Ropa\"],\n  \"barcode\": \"{{createdProductBarcode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          },
          "response": []
        },
